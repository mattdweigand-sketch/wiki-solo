{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wiki-classifier-artifact.schema.json",
  "title": "Wiki classifier artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "classifier_version",
    "provider",
    "source_path",
    "primary_home",
    "page_home_mode",
    "confidence",
    "rationale",
    "findings",
    "human_review_required",
    "writes_wiki",
    "provider_metadata"
  ],
  "properties": {
    "classifier_version": {
      "const": "wiki-classifier.v1"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "source_path": {
      "type": ["string", "null"]
    },
    "primary_home": {
      "type": ["string", "null"]
    },
    "page_home_mode": {
      "enum": [
        "source_only",
        "source_plus_existing_updates",
        "source_plus_new_analysis",
        "decision_capture",
        "workflow_update_candidate",
        "no_op",
        null
      ]
    },
    "confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "rationale": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_review_required": {
      "type": "boolean"
    },
    "writes_wiki": {
      "const": false
    },
    "provider_metadata": {
      "type": "object"
    }
  }
}
