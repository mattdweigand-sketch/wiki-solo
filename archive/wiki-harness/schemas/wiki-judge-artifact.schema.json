{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wiki-judge-artifact.schema.json",
  "title": "Wiki judge artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "judge_version",
    "provider",
    "decision",
    "policy_status",
    "writer_provider",
    "scores",
    "findings",
    "human_review_required",
    "writes_wiki",
    "provider_metadata"
  ],
  "properties": {
    "judge_version": {
      "const": "wiki-judge.v1"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "enum": ["approve_for_review", "needs_revision", "reject"]
    },
    "policy_status": {
      "enum": ["pass", "review", "reject", "unknown"]
    },
    "writer_provider": {
      "type": ["string", "null"]
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_correctness",
        "source_fidelity",
        "citation_adequacy",
        "link_quality",
        "scope_discipline"
      ],
      "properties": {
        "route_correctness": {
          "type": ["number", "null"]
        },
        "source_fidelity": {
          "type": ["number", "null"]
        },
        "citation_adequacy": {
          "type": ["number", "null"]
        },
        "link_quality": {
          "type": ["number", "null"]
        },
        "scope_discipline": {
          "type": ["number", "null"]
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_review_required": {
      "type": "boolean"
    },
    "writes_wiki": {
      "const": false
    },
    "provider_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["visual_source_evidence"],
      "properties": {
        "visual_source_evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "evidence_extraction_performed",
            "evidence_source",
            "visible_text_summary"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "evidence_extraction_performed": {
              "type": "boolean"
            },
            "evidence_source": {
              "enum": ["visual", "ocr", "human_verified", "none"]
            },
            "visible_text_summary": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
