{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wiki-visual-evidence-artifact.schema.json",
  "title": "Wiki visual evidence artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "visual_evidence_version",
    "provider",
    "source_path",
    "primary_home",
    "required",
    "evidence_extraction_performed",
    "evidence_source",
    "visible_text_summary",
    "findings",
    "human_review_required",
    "writes_wiki",
    "provider_metadata"
  ],
  "properties": {
    "visual_evidence_version": {
      "const": "wiki-visual-evidence.v1"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "primary_home": {
      "type": "string",
      "minLength": 1
    },
    "required": {
      "type": "boolean"
    },
    "evidence_extraction_performed": {
      "type": "boolean"
    },
    "evidence_source": {
      "enum": ["visual", "ocr", "human_verified", "none"]
    },
    "visible_text_summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_review_required": {
      "type": "boolean"
    },
    "writes_wiki": {
      "const": false
    },
    "provider_metadata": {
      "type": "object"
    }
  }
}
