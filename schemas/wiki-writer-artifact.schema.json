{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wiki-writer-artifact.schema.json",
  "title": "Wiki writer artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "writer_version",
    "provider",
    "source_path",
    "primary_home",
    "draft_path",
    "writes_wiki",
    "provider_metadata"
  ],
  "properties": {
    "writer_version": {
      "const": "wiki-writer.v1"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "primary_home": {
      "type": "string",
      "minLength": 1
    },
    "draft_path": {
      "type": "string",
      "minLength": 1
    },
    "writes_wiki": {
      "const": false
    },
    "provider_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["visual_source_evidence"],
      "properties": {
        "visual_source_evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "evidence_extraction_performed",
            "evidence_source",
            "visible_text_summary"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "evidence_extraction_performed": {
              "type": "boolean"
            },
            "evidence_source": {
              "enum": ["visual", "ocr", "human_verified", "none"]
            },
            "visible_text_summary": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
