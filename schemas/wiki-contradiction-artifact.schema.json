{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wiki-contradiction-artifact.schema.json",
  "title": "Wiki contradiction detector artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contradiction_detector_version",
    "provider",
    "source_path",
    "primary_home",
    "status",
    "potential_contradictions",
    "findings",
    "human_review_required",
    "writes_wiki",
    "provider_metadata"
  ],
  "properties": {
    "contradiction_detector_version": {
      "const": "wiki-contradiction-detector.v1"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "source_path": {
      "type": ["string", "null"]
    },
    "primary_home": {
      "type": ["string", "null"]
    },
    "status": {
      "enum": ["no_conflict_found", "potential_conflict", "blocked"]
    },
    "potential_contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "proposed_claim",
          "conflicting_page",
          "new_source_evidence",
          "existing_page_evidence",
          "confidence",
          "recommended_action"
        ],
        "properties": {
          "proposed_claim": {
            "type": "string"
          },
          "conflicting_page": {
            "type": "string"
          },
          "new_source_evidence": {
            "type": "string"
          },
          "existing_page_evidence": {
            "type": "string"
          },
          "confidence": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1
          },
          "recommended_action": {
            "enum": ["no_conflict", "caveat", "contradiction_log", "human_review"]
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "human_review_required": {
      "type": "boolean"
    },
    "writes_wiki": {
      "const": false
    },
    "provider_metadata": {
      "type": "object"
    }
  }
}
